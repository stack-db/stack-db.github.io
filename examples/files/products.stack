title: Google Product Taxonomy
first_card: '@about'
version: 0.1
nodes:
- handle: about
  tags:
  - meta
  fields:
    title: Google Product Taxonomy
    version: '2021-09-21'
    url: https://support.google.com/merchants/answer/6324436
    about: Google's product taxonomy used by Google Merchant Center to categorize products. All products are automatically assigned a category from this continuously evolving taxonomy. Providing high-quality, on-topic titles and descriptions, as well as accurate pricing, brand, and GTIN information will help ensure products are correctly categorized.
    publisher: Google
